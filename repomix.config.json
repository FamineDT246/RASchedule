{
  "output": {
    "filePath": "download/ra-syncbot-repomix.xml",
    "style": "xml",
    "showLineNumbers": true,
    "removeComments": false,
    "headerText": "RA Syncbot — Camp & Workshop Instructor Scheduling\nProduction codebase for AI audit.\nRepository: https://github.com/FamineDT246/RASchedule\nLive site: https://ra-syncbot.com"
  },
  "include": [
    "**/*"
  ],
  "ignore": [
    "node_modules/**",
    ".pnp.*",
    ".yarn/**",
    ".next/**",
    "out/**",
    "build/**",
    "*.tsbuildinfo",
    "next-env.d.ts",
    ".env",
    ".env.*",
    "!.env.example",
    "db/*.db",
    "db/*.db-journal",
    "*.sqlite",
    "*.sqlite3",
    ".vercel/**",
    ".git/**",
    ".DS_Store",
    "*.pem",
    "*.log",
    "dev.log",
    "dev.out.log",
    "server.log",
    "coverage/**",
    "local-*",
    ".claude/**",
    ".z-ai-config",
    "tool-results/**",
    "test",
    "prompt",
    "upload/**",
    ".idea/**",
    ".vscode/**",
    "*.swp",
    "*.swo",
    "Thumbs.db",
    "ehthumbs.db",
    "Desktop.ini",
    "$RECYCLE.BIN/**",
    "download/**",
    "*.zip",
    "skills/**",
    "bun.lock"
  ]
}
