# ─────────────────────────────────────────────────────────────────────────
# RA Syncbot — Environment Variables
# ─────────────────────────────────────────────────────────────────────────
# Copy this file to .env and fill in your values.
# Never commit .env to git!

# ── Database (REQUIRED for production) ────────────────────────────────────
# Turso cloud database (libSQL). Get these from:
#   turso db show your-db-name --url
#   turso db tokens create your-db-name

TURSO_URL=libsql://your-db-name.turso.io
TURSO_AUTH_TOKEN=your-turso-auth-token-here

# ── Database (OPTIONAL — local development fallback) ─────────────────────
# If TURSO_URL is not set, the app falls back to this local SQLite file.
# Only used in development.

DATABASE_URL=file:./db/custom.db

# ── Session (REQUIRED for production) ─────────────────────────────────────
# Used to HMAC-sign auth cookies via the Web Crypto API.
# Must be at least 32 characters. Generate one with:
#   openssl rand -hex 32

SESSION_PASSWORD=changeme-this-must-be-at-least-32-characters-long!!

# ── Email notifications (OPTIONAL — skip if not using) ───────────────────
# Get these from https://resend.com (free tier: 100 emails/day, 3000/month)
# If RESEND_API_KEY is not set, email notifications are silently skipped
# and the account-claim flow skips email verification (dev mode).

RESEND_API_KEY=re_xxxxxxxxxxxxxxxxxxxxxxxxxxxx
FROM_EMAIL=onboarding@resend.dev

# ── Admin notifications (OPTIONAL) ───────────────────────────────────────
# Receives an email when an instructor opts in to an event.
# If not set, opt-in notifications are skipped.

ADMIN_EMAIL=admin@yourdomain.com
